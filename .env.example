# opensource-release-watcher environment example
#
# Copy this file to .env and update paths/domains before deployment.

# Application runtime.
SERVER_ADDR=127.0.0.1:8000
DB_PATH=./data/watcher.db
GITHUB_TOKEN=
CHECK_INTERVAL=6h

# Email notifications. Leave empty to disable actual SMTP sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Public HTTPS endpoint handled by nginx during deployment.
DOMAIN=watcher.example.com
EXTERNAL_PORT=443
CERT_PATH=/etc/letsencrypt/live/watcher.example.com/fullchain.pem
KEY_PATH=/etc/letsencrypt/live/watcher.example.com/privkey.pem
CLIENT_MAX_BODY_SIZE=200M
